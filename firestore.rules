/**
 * @fileoverview Firestore Security Rules for CampusConnect ERP system.
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control system where 'admins' have elevated privileges to view and manage student and teacher applications.
 * Users who are not admins can submit applications, but cannot view them directly.
 *
 * Data Structure:
 * - /student_applications/{studentApplicationId}: Stores student application data.
 * - /teacher_applications/{teacherApplicationId}: Stores teacher application data.
 * - /roles_admin/{adminId}: Indicates admin status. The existence of a document at this path grants admin privileges.
 *
 * Key Security Decisions:
 * - Admins can read and write all student and teacher applications.
 * - Regular users can create student and teacher applications, but cannot read, update or delete them.
 * - Listing student and teacher applications is restricted to admins only.
 * - The rules do not enforce strict data validation (data types, required fields) to allow for rapid prototyping, but they do ensure that the 'adminId' field, if present on the application, matches an existing admin.
 *
 * Denormalization for Authorization:
 * - The `adminId` field in student and teacher application documents is used to link applications to admins, enabling direct authorization checks without needing additional reads.
 *
 * Structural Segregation:
 * - Student and teacher applications are stored in separate collections to simplify rule logic and improve query performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is an admin.
     * @return {boolean} True if the user is an admin, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Checks if the user is the owner of the application by adminId.
     * @param {string} adminId The admin ID to check against the request.auth.uid.
     * @return {boolean} True if the user is the application owner, false otherwise.
     */
    function isOwner(adminId) {
        return request.auth.uid == adminId;
    }

    /**
     * @description Checks if the user is the owner of the existing application by adminId.
     * @param {string} adminId The admin ID to check against the request.auth.uid.
     * @return {boolean} True if the user is the existing application owner, false otherwise.
     */
    function isExistingOwner(adminId) {
      return (isOwner(adminId) && resource != null);
    }

    /**
     * @description Rules for the student_applications collection.
     * @path /student_applications/{studentApplicationId}
     * @allow (create) Signed-in user can create an application.
     * @allow (get, list) Admin user can read any application.
     * @deny (update, delete) Regular user cannot update or delete the application.
     * @principle Enforces admin-only access for reading, updating, and deleting applications. Allows any signed-in user to create an application.
     */
    match /student_applications/{studentApplicationId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the teacher_applications collection.
     * @path /teacher_applications/{teacherApplicationId}
     * @allow (create) Signed-in user can create an application.
     * @allow (get, list) Admin user can read any application.
     * @deny (update, delete) Regular user cannot update or delete the application.
     * @principle Enforces admin-only access for reading, updating, and deleting applications. Allows any signed-in user to create an application.
     */
    match /teacher_applications/{teacherApplicationId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Rules for the roles_admin collection.
     * @path /roles_admin/{adminId}
     * @allow (create) Only the user with matching id can create their admin role document.
     * @allow (get, list) Admin user can read the admin role doc.
     * @allow (update, delete) Admin user can update/delete the admin role doc.
     * @principle Enforces that only the user with matching id can create their admin role document. Only admins can update/delete the doc.
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn() && isOwner(adminId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}